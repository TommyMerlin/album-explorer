# 数据根目录（包含图像文件和 album-assetizer 生成的数据库）
ALBUM_EXPLORER_BASE=/path/to/your/album-data

# album-assetizer 生成的 SQLite 数据库路径
ALBUM_EXPLORER_DB=/path/to/your/album-data/.album-assetizer/state/album_assetizer.db

# 图像文件根目录（用于原图访问）
ALBUM_EXPLORER_IMAGE_ROOT=/path/to/your/album-data

# 缩略图缓存目录
ALBUM_EXPLORER_THUMBS=./data/thumbnails

# 向量文件目录（embedding + neighbors）
ALBUM_EXPLORER_VECTORS=./data/vectors

# 数据库本地缓存目录（WSL2 跨文件系统加速用）
ALBUM_EXPLORER_CACHE=/tmp/album-explorer

# 删除图片时的回收站目录
ALBUM_EXPLORER_TRASH=./data/.trash

# 后端服务端口
ALBUM_EXPLORER_PORT=8000

# CORS 允许的源（逗号分隔）
ALBUM_EXPLORER_CORS_ORIGINS=http://localhost:3000,http://localhost:5173
